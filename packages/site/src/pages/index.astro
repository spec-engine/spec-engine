---
// Spec Engine landing page — ported from the brand kit's
// "Spec Engine Landing.dc.html" (Claude design project). Custom Astro page:
// it replaces the Starlight splash and carries its own head/chrome.
const GITHUB = "https://github.com/spec-engine/spec-engine";
const DOCS = "/overview/";

// Coverage-cell + status-pill encodings, ported from the design's DCLogic
// (colorblind glyphs on, accent #C4F135).
const cellBase =
  "width:26px;height:26px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-family:var(--f-mono);font-size:13px;font-weight:700;line-height:1;";
const cells = {
  both: {
    glyph: "✓",
    style: `${cellBase}color:var(--verified);background:var(--verified-soft);border:1px solid var(--verified-line)`,
  },
  src: {
    glyph: "S",
    style: `${cellBase}color:var(--acc);background:var(--acc-soft);border:1px solid var(--acc-line)`,
  },
  test: {
    glyph: "T",
    style: `${cellBase}color:var(--acc);background:transparent;border:1px solid var(--acc-line)`,
  },
  none: { glyph: "", style: `${cellBase}border:1px dashed var(--line-d2)` },
};
const pillBase =
  "font-family:var(--f-mono);font-size:10px;font-weight:600;letter-spacing:0.05em;justify-self:end;padding:4px 9px;border-radius:4px;";
const pills = {
  VERIFIED: `${pillBase}color:var(--acc-ink);background:var(--acc)`,
  DRIFT: `${pillBase}color:var(--drift);background:color-mix(in srgb,var(--drift) 15%,transparent);border:1px solid color-mix(in srgb,var(--drift) 40%,transparent)`,
  BROKEN: `${pillBase}color:var(--broken);background:color-mix(in srgb,var(--broken) 15%,transparent);border:1px solid color-mix(in srgb,var(--broken) 40%,transparent)`,
};
const mk = (id, title, cov, status) => ({
  id,
  title,
  status,
  pill: pills[status],
  cells: cov.map((s) => cells[s]),
});
const rows = [
  mk(
    "SPEC-0011",
    "Rate limit: 100 req / min / key",
    ["both", "both", "src", "none", "both"],
    "VERIFIED",
  ),
  mk("SPEC-0042", "Refunds are idempotent", ["none", "src", "both", "none", "none"], "DRIFT"),
  mk(
    "SPEC-0014",
    "Exports scoped to the tenant",
    ["src", "both", "none", "none", "none"],
    "BROKEN",
  ),
  mk(
    "SPEC-0002",
    "PII never logged in plaintext",
    ["both", "both", "both", "both", "src"],
    "VERIFIED",
  ),
];
const gm =
  "width:16px;height:16px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-family:var(--f-mono);font-size:10px;font-weight:700;line-height:1;";
const coverageLegend = [
  {
    glyph: "✓",
    label: "verified",
    style: `${gm}color:var(--verified);background:var(--verified-soft);border:1px solid var(--verified-line)`,
  },
  {
    glyph: "S",
    label: "src only",
    style: `${gm}color:var(--acc);background:var(--acc-soft);border:1px solid var(--acc-line)`,
  },
  {
    glyph: "T",
    label: "test only",
    style: `${gm}color:var(--acc);border:1px solid var(--acc-line)`,
  },
  { glyph: "", label: "none", style: `${gm}border:1px dashed var(--line-d2)` },
];
const surfaces = ["API", "Web app", "Mobile", "Internal admin", "Support tools", "Customer portal"];
const matrixRepos = ["web", "api", "worker", "mobile", "cli"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Spec Engine — Keep your coding agents honest.</title>
    <meta name="description" content="Durable specs. Permanent IDs. Drift caught in CI before it ships." />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0F1214" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Spec Engine" />
    <meta property="og:title" content="Keep your coding agents honest." />
    <meta property="og:description" content="Durable specs. Permanent IDs. Drift caught in CI before it ships." />
    <meta property="og:url" content="https://docs.spec-engine.dev/" />
    <meta property="og:image" content="https://docs.spec-engine.dev/og-spec-engine.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Keep your coding agents honest." />
    <meta name="twitter:description" content="Durable specs. Permanent IDs. Drift caught in CI before it ships." />
    <meta name="twitter:image" content="https://docs.spec-engine.dev/og-spec-engine.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --ink: #0f1214;
        --charcoal: #151a1e;
        --panel: #14181b;
        --elev: #1e262b;
        --bone: #f1eee6;
        --paper: #fbfaf5;
        --line-d: rgba(255, 255, 255, 0.09);
        --line-d2: rgba(255, 255, 255, 0.16);
        --line-l: #e3e0d6;
        --fg-d: #e7e4db;
        --dim-d: #a7acb0;
        --mute-d: #868d94;
        --fg-l: #1b2024;
        --dim-l: #4a5157;
        --mute-l: #868d94;
        --acc: #c4f135;
        --acc-ink: #0f1214;
        --acc-soft: color-mix(in srgb, var(--acc) 15%, transparent);
        --acc-line: color-mix(in srgb, var(--acc) 42%, transparent);
        --verified: #c4f135;
        --verified-soft: color-mix(in srgb, #c4f135 15%, transparent);
        --verified-line: color-mix(in srgb, #c4f135 45%, transparent);
        --drift: #e8a317;
        --broken: #f0472e;
        --unbound: #868d94;
        --grid-op: 1;
        --f-disp: "Archivo";
        --f-sans: "IBM Plex Sans";
        --f-mono: "IBM Plex Mono";
      }
      * {
        box-sizing: border-box;
      }
      html {
        -webkit-font-smoothing: antialiased;
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        font-family: var(--f-sans), system-ui, sans-serif;
        color: var(--fg-d);
        background: var(--ink);
      }
      ::selection {
        background: var(--acc);
        color: var(--acc-ink);
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      .hov-fg:hover {
        color: var(--fg-d) !important;
      }
      .btn-acc:hover {
        filter: brightness(0.94);
      }
      .btn-ghost:hover {
        border-color: var(--fg-d) !important;
      }
      @media (max-width: 820px) {
        [data-stack] {
          grid-template-columns: 1fr !important;
          gap: 28px !important;
        }
        header nav {
          display: none !important;
        }
        [data-mobile-hide] {
          display: none !important;
        }
        [data-mobile-bar] {
          display: flex !important;
        }
        [data-matrix] {
          overflow-x: auto !important;
        }
        [data-matrix] > div {
          min-width: 560px;
        }
      }
    </style>
  </head>
  <body>
    <div style="background:var(--ink);overflow-x:hidden">
      <!-- ============ NAV ============ -->
      <header
        style="position:sticky;top:0;z-index:50;background:color-mix(in srgb,var(--ink) 90%,transparent);backdrop-filter:blur(10px);border-bottom:1px solid var(--line-d)"
      >
        <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:28px;padding:15px 28px">
          <a href="#top" style="display:flex;align-items:center;gap:10px">
            <svg width="24" height="24" viewBox="0 0 64 64" fill="none"
              ><path d="M25 13 H13 V51 H25" stroke="var(--fg-d)" stroke-width="6"></path><path
                d="M39 13 H51 V51 H39"
                stroke="var(--fg-d)"
                stroke-width="6"></path><rect x="26" y="26" width="12" height="12" fill="var(--acc)"></rect><line
                x1="32"
                y1="13"
                x2="32"
                y2="24"
                stroke="var(--fg-d)"
                stroke-width="4"></line><line x1="32" y1="40" x2="32" y2="51" stroke="var(--fg-d)" stroke-width="4"
              ></line></svg
            >
            <span style="font-family:var(--f-disp);font-weight:800;font-size:16px;letter-spacing:-0.01em"
              >Spec Engine</span
            >
          </a>
          <nav style="display:flex;gap:26px;font-size:14px;color:var(--dim-d)">
            <a href="#how" class="hov-fg" style="color:var(--dim-d)">How it works</a>
            <a href="#product" class="hov-fg" style="color:var(--dim-d)">Product</a>
            <a href="#drift" class="hov-fg" style="color:var(--dim-d)">Drift gate</a>
            <a href="#features" class="hov-fg" style="color:var(--dim-d)">Features</a>
          </nav>
          <span style="flex:1"></span>
          <a href={DOCS} data-mobile-hide class="hov-fg" style="font-size:14px;color:var(--dim-d)">Docs</a>
          <a
            href={GITHUB}
            data-mobile-hide
            class="btn-acc"
            style="display:inline-flex;align-items:center;gap:7px;font-family:var(--f-disp);font-weight:700;font-size:14px;background:var(--acc);color:var(--acc-ink);border-radius:6px;padding:9px 16px"
            ><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" style="flex:none"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8 8 0 008 0z"
              ></path></svg
            >Start free</a
          >
        </div>
      </header>

      <!-- ============ HERO ============ -->
      <section id="top" style="position:relative;overflow:hidden;border-bottom:1px solid var(--line-d)">
        <div
          style="position:absolute;inset:0;pointer-events:none;opacity:var(--grid-op);background-image:linear-gradient(rgba(255,255,255,0.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.045) 1px,transparent 1px);background-size:40px 40px"
        >
        </div>
        <div
          data-stack
          style="position:relative;max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1.05fr 0.95fr;gap:54px;align-items:center;padding:92px 28px 96px"
        >
          <div>
            <div
              style="display:inline-flex;align-items:center;gap:9px;font-family:var(--f-mono);font-size:12px;letter-spacing:0.16em;color:var(--acc);margin-bottom:26px"
            >
              <span style="width:7px;height:7px;background:var(--acc);display:inline-block"></span>DETERMINISTIC BY
              DESIGN
            </div>
            <h1
              style="font-family:var(--f-disp);font-weight:900;font-size:clamp(31px,4.7vw,52px);line-height:1.2;letter-spacing:-0.035em;margin:0"
            >
              Keep your<br /><span style="white-space:nowrap"
                >coding agents <span style="background:var(--acc);color:var(--acc-ink);padding:0 8px">honest.</span
                ></span
              >
            </h1>
            <p style="font-size:18px;line-height:1.6;color:var(--dim-d);max-width:520px;margin:26px 0 0">
              Write your requirements as durable specs with permanent IDs. Spec Engine binds them to the real code
              across every repo and catches drift in CI, before it ships.
            </p>
            <div style="display:flex;gap:13px;margin-top:34px;flex-wrap:wrap">
              <a
                href={GITHUB}
                class="btn-acc"
                style="display:inline-flex;align-items:center;gap:10px;font-family:var(--f-disp);font-weight:700;font-size:15px;background:var(--acc);color:var(--acc-ink);border-radius:7px;padding:14px 24px"
                ><svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor" style="flex:none"
                  ><path
                    d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8 8 0 008 0z"
                  ></path></svg
                >Start free</a
              >
              <a
                href={DOCS}
                class="btn-ghost"
                style="font-family:var(--f-disp);font-weight:700;font-size:15px;color:var(--fg-d);border:1.5px solid var(--line-d2);border-radius:7px;padding:13px 24px"
                >Read the docs</a
              >
            </div>
            <div
              style="display:flex;align-items:center;gap:18px;margin-top:30px;font-family:var(--f-mono);font-size:12px;color:var(--mute-d);flex-wrap:wrap"
            >
              <span style="display:flex;align-items:center;gap:7px"
                ><span style="width:8px;height:8px;border-radius:2px;background:var(--verified)"></span>verified</span
              >
              <span style="display:flex;align-items:center;gap:7px"
                ><span style="width:8px;height:8px;border-radius:2px;background:var(--drift)"></span>drift</span
              >
              <span style="display:flex;align-items:center;gap:7px"
                ><span style="width:8px;height:8px;border-radius:2px;background:var(--broken)"></span>broken</span
              >
              <span>caught in CI, per requirement</span>
            </div>
          </div>

          <!-- hero product panel -->
          <div
            style="background:var(--panel);border:1px solid var(--line-d);border-radius:11px;overflow:hidden;box-shadow:0 30px 70px rgba(0,0,0,0.5)"
          >
            <div
              style="display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:1px solid var(--line-d);background:var(--charcoal)"
            >
              <span style="width:9px;height:9px;border-radius:50%;background:#3A424A"></span><span
                style="width:9px;height:9px;border-radius:50%;background:#3A424A"></span><span
                style="width:9px;height:9px;border-radius:50%;background:#3A424A"></span>
              <span style="font-family:var(--f-mono);font-size:11px;color:var(--mute-d);margin-left:8px"
                >specs/billing.spec.md</span
              >
            </div>
            <div style="padding:20px;font-family:var(--f-mono);font-size:13px;line-height:1.9">
              <div>
                <span style="color:var(--mute-d)">## </span><span style="color:var(--acc)">[SPEC-0042]</span>
                <span style="color:var(--fg-d)">Refunds are idempotent</span>
              </div>
              <div style="color:var(--dim-d);padding-left:20px">Replaying a refund with the same key</div>
              <div style="color:var(--dim-d);padding-left:20px">must never issue a second refund.</div>
            </div>
            <div style="border-top:1px solid var(--line-d);padding:16px 20px;display:flex;flex-direction:column;gap:11px">
              <div style="display:flex;align-items:center;gap:10px;font-family:var(--f-mono);font-size:12px">
                <span style="color:var(--mute-d);width:52px">impl</span><span style="color:var(--dim-d);flex:1"
                  >worker/refunds/handler.ts:44</span
                ><span style="color:var(--dim-d)">agent·Claude</span>
              </div>
              <div style="display:flex;align-items:center;gap:10px;font-family:var(--f-mono);font-size:12px">
                <span style="color:var(--mute-d);width:52px">test</span><span style="color:var(--dim-d);flex:1"
                  >worker/refunds/handler.test.ts</span
                ><span style="color:var(--dim-d)">ci·unit</span>
              </div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-top:5px">
                <span style="font-family:var(--f-mono);font-size:11px;color:var(--mute-d)">bound across 3 repos</span>
                <span
                  style="display:inline-flex;align-items:center;gap:7px;font-family:var(--f-mono);font-size:11px;font-weight:600;color:var(--acc-ink);background:var(--acc);border-radius:5px;padding:5px 10px"
                  ><svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                    ><path d="M5 12 L10 17 L19 6" stroke="var(--acc-ink)" stroke-width="2.4"></path></svg
                  >VERIFIED</span
                >
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ QUICK START BAR ============ -->
      <div style="background:var(--charcoal);border-bottom:1px solid var(--line-d)">
        <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:24px;flex-wrap:wrap;padding:16px 28px">
          <span style="font-family:var(--f-mono);font-size:11px;letter-spacing:0.12em;color:var(--mute-d)"
            >QUICK START</span
          >
          <div
            style="display:flex;align-items:center;gap:13px;background:var(--ink);border:1px solid var(--line-d2);border-radius:8px;padding:11px 16px;font-family:var(--f-mono);font-size:14px"
          >
            <span style="color:var(--acc)">$</span>
            <span id="quickstart-cmd" style="color:var(--fg-d)">bun add -g @spec-engine/spec-engine</span>
            <span style="width:1px;height:16px;background:var(--line-d2)"></span>
            <button
              id="quickstart-copy"
              aria-label="Copy install command"
              style="all:unset;display:flex;cursor:pointer"
              ><svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                ><rect x="8" y="8" width="12" height="12" rx="2" stroke="var(--mute-d)" stroke-width="1.75"
                ></rect><path d="M5 16 V6 A2 2 0 017 4 H15" stroke="var(--mute-d)" stroke-width="1.75"></path></svg
              ></button
            >
          </div>
        </div>
      </div>

      <!-- ============ IDEA / PILLARS ============ -->
      <section style="background:var(--bone);color:var(--fg-l);border-bottom:1px solid var(--line-l)">
        <div style="max-width:1200px;margin:0 auto;padding:92px 28px">
          <div style="font-family:var(--f-mono);font-size:12px;letter-spacing:0.16em;color:var(--mute-l);margin-bottom:26px">
            WHY IT HOLDS
          </div>
          <p
            style="font-family:var(--f-disp);font-weight:700;font-size:clamp(26px,3.4vw,40px);line-height:1.2;letter-spacing:-0.025em;max-width:940px;margin:0"
          >
            Spec Engine treats a requirement like a <span
              style="background:var(--acc);color:var(--acc-ink);padding:0 8px">machined part</span
            >: stamped with a permanent ID, bound to the code that implements it, and measured continuously for drift.
          </p>
          <div
            style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1px;background:var(--line-l);border:1px solid var(--line-l);margin-top:56px"
          >
            <div style="background:var(--paper);padding:30px 26px">
              <div style="font-family:var(--f-mono);font-size:12px;color:#8A7400;letter-spacing:0.06em">
                DETERMINISTIC
              </div>
              <p style="font-size:15px;line-height:1.6;color:var(--dim-l);margin:13px 0 0">
                A spec resolves to one answer: implemented, verified, drifted, or broken. No ambiguity, no vibes.
              </p>
            </div>
            <div style="background:var(--paper);padding:30px 26px">
              <div style="font-family:var(--f-mono);font-size:12px;color:#8A7400;letter-spacing:0.06em">MECHANICAL</div>
              <p style="font-size:15px;line-height:1.6;color:var(--dim-l);margin:13px 0 0">
                Specs clamp to code like tooling to a workpiece. Move the code, the binding follows or flags.
              </p>
            </div>
            <div style="background:var(--paper);padding:30px 26px">
              <div style="font-family:var(--f-mono);font-size:12px;color:#8A7400;letter-spacing:0.06em">TRUSTWORTHY</div>
              <p style="font-size:15px;line-height:1.6;color:var(--dim-l);margin:13px 0 0">
                CI is the referee. Drift is caught before it ships, not discovered in production a quarter later.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ PRDs ============ -->
      <section style="position:relative;overflow:hidden;border-bottom:1px solid var(--line-d)">
        <div
          style="position:absolute;inset:0;pointer-events:none;opacity:var(--grid-op);background-image:linear-gradient(rgba(255,255,255,0.045) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.045) 1px,transparent 1px);background-size:40px 40px"
        >
        </div>
        <div style="position:relative;max-width:1200px;margin:0 auto;padding:90px 28px">
